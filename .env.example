# CodeSense Backend Environment Configuration
# Copy this to .env and adjust for your setup

# ─── APP ──────────────────────────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ─── CORS (add your frontend URL) ─────────────────────────────────────────────
# ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── LLM BACKEND ──────────────────────────────────────────────────────────────
# Options: "ollama" | "hf" | "mock"
# - ollama: Runs Mistral-7B locally via Ollama (recommended for judges)
# - hf: Uses HuggingFace Inference API (requires token)
# - mock: Rule-based fallback, no GPU needed (for demo without GPU)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct

# HuggingFace settings (used when LLM_BACKEND=hf)
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
HF_API_TOKEN=

# LLM parameters
LLM_TIMEOUT=30.0
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.4

# ─── EXECUTION SANDBOX ────────────────────────────────────────────────────────
EXECUTION_TIMEOUT=5
EXECUTION_MEMORY_MB=64
MAX_OUTPUT_CHARS=4096

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
